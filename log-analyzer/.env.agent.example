# ─── REQUIRED ────────────────────────────────────────────────────────────────

# Уникальный идентификатор ноды. Будет показан в дашборде и записан в node_id
# колонку всех таблиц. Менять можно — но при смене связь с историей теряется.
# Примеры: germany-1, ru-bridge, poland-1, finland-1
NODE_ID=germany-1

# WebSocket endpoint analyzer-сервера (через reverse-proxy с TLS).
SERVER_URL=wss://analyzer.example.com/ws

# Bearer token. Должен совпадать с AGENT_TOKEN в .env сервера.
AUTH_TOKEN=


# ─── Log file paths ─────────────────────────────────────────────────────────

# Директория с access.log на host'е (mount'ится как read-only в контейнер).
# Стандарт для Remnawave-нод — /var/log/remnanode.
LOG_HOST_PATH=/var/log/remnanode

# Путь к access.log внутри контейнера (обычно не нужно менять).
LOG_FILE_PATH=/var/log/remnanode/access.log


# ─── Batching ───────────────────────────────────────────────────────────────

# Сколько записей собирать перед отправкой WS-кадра.
# 1000 = разумный baseline. >5000 при очень high-volume нодах.
BATCH_SIZE=1000

# Максимальное время до flush'а батча (Go duration format).
BATCH_TIMEOUT=5s

# gzip сжатие WS payload (рекомендуется true).
ENABLE_COMPRESSION=true


# ─── Reconnect tuning (опционально) ─────────────────────────────────────────

# Начальная пауза между reconnect-попытками.
RECONNECT_INTERVAL=1s

# Максимальная пауза (exponential backoff).
MAX_RECONNECT_INTERVAL=30s

# Множитель для exponential backoff.
RECONNECT_MULTIPLIER=1.5
