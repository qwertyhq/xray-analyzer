# Настройки Telegram бота (опционально)
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Пороги для алертов
# Количество запросов к запрещённым сайтам для срабатывания алерта
SUSPICIOUS_REQUEST_COUNT=5
# Временное окно для подсчёта (Go duration format)
SUSPICIOUS_TIME_WINDOW=1h
