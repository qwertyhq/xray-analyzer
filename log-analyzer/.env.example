# Настройки Telegram бота (опционально)
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Пороги для алертов
# Количество запросов к запрещённым сайтам для срабатывания алерта
SUSPICIOUS_REQUEST_COUNT=5
# Временное окно для подсчёта (Go duration format)
SUSPICIOUS_TIME_WINDOW=1h

# Remnawave API integration (опционально)
# Включить интеграцию с Remnawave для получения данных о пользователях, HWID устройствах и т.д.
REMNAWAVE_ENABLED=false
REMNAWAVE_URL=https://your-remnawave-panel.com
REMNAWAVE_API_TOKEN=your_jwt_api_token_here
# Интервал синхронизации данных (Go duration format)
REMNAWAVE_SYNC_INTERVAL=5m

# Mapbox API для карты географического распределения (опционально)
# Получите токен на https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here
